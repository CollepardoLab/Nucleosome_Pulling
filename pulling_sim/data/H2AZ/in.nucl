special_bonds fene
neighbor 10 bin
group nucl id 46:136 159:239 257:354 399:493 539:629 652:732 750:847 892:986
group dna type 41
group ps type 42
group dna_all union dna ps
group notdna subtract all dna_all
neigh_modify exclude molecule/intra nucl
neigh_modify exclude molecule/intra dna_all 
neigh_modify exclude type 41 42
neigh_modify exclude type 41 41
variable ex equal "sqrt((x[987] - x[1617])^2 + (y[987] - y[1617])^2 + (z[987] - z[1617])^2)"
group end1 id 987
group end2 id 1617
group P1 id 988
group P2 id 989
group p3 id 1618
group p4 id 1619

thermo_style    custom step temp pe ebond ke etotal spcpu

thermo          10000

timer timeout 35:10:00
restart 100000 nucl.restart.1 nucl.restart.2



comm_style tiled


compute q dna property/atom quatw quati quatj quatk
compute shape dna property/atom shapex shapey shapez


dump      1 all custom 10000 dna_${I}.dump &
             id x y z c_q[1] c_q[2] c_q[3] c_q[4] &
              c_shape[1] c_shape[2] c_shape[3] mol q type

dump_modify 1 sort id

# first minimise the tails

fix 1 notdna nve
fix 2 notdna viscous 1000000.0


timestep 0.0001

run 1000


timestep 0.001

run 1000


timestep 0.01

run 5000


unfix 2


fix 2 notdna viscous 10000.0


timestep 0.1

run 2000

timestep 5.0

run 2000

timestep 10.0

run 5000

unfix 1
unfix 2


fix 3 notdna langevin 0.0 300 1000.0 5512 gjf vfull
fix 5 dna langevin 0.0 300 1000.0 5512 angmom 3.0 gjf vfull


timestep 10.0


fix bl all balance 1000 1.0 rcb

run 10000




unfix 3
unfix 5
unfix bl


fix 3 notdna langevin 300 300 100000.0 ${SEED} gjf vfull
fix 5 dna langevin 300 300 100000.0 ${SEED} angmom 3.0 gjf vfull


fix 4 dna_all rigid/nve/small molecule
fix 2 notdna nve

fix bl all balance 1000 1.0 rcb

timestep 40.0


run 2000000


thermo_style    custom step temp pe ebond ke spcpu v_ex


thermo          10000



fix spring1 end1 smd cvel 0.1 0.0 couple end2 0 0 25 0

run 25000

fix spring1 end1 smd cvel 0.01 0.000009 couple end2 0 0 25 0

run 2500000

